# ==========================================
# バックエンド環境変数テンプレート
# ==========================================
# .env にコピーして編集してください

# Node環境
NODE_ENV=production

# ポート
PORT=3000

# JWT認証
JWT_SECRET=your-secret-key-change-in-production

# ウォレット・スマートコントラクト
# Polygon Mainnet RPC
RPC_URL=https://polygon-rpc.com

# JPYC コントラクトアドレス（デプロイ後）
JPYC_CONTRACT_ADDRESS=0x...

# バックエンドの秘密鍵（絶対にGitHubにコミットしない！）
TRANSFER_PRIVATE_KEY=0x...

# データベース
DATABASE_URL=postgresql://user:password@localhost:5432/jpyc_poikatsu

# Redis
REDIS_URL=redis://localhost:6379

# 監視・ログ
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxxx

# 広告ネットワーク
ADMOB_CLIENT_ID=xxx.apps.googleusercontent.com

# 外部API
ETHERSCAN_API_KEY=your-etherscan-api-key
INFURA_API_KEY=your-infura-api-key
